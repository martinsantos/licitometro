# =============================================================================
# Licitometro - Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# --- MongoDB ---
MONGO_URL=mongodb://mongodb:27017
DB_NAME=licitaciones_db

# --- Storage Limits ---
STORAGE_MAX_MB=500
RUN_HISTORY_KEEP=10
CACHE_TTL_HOURS=168
LOG_RETENTION_DAYS=7

# --- Frontend ---
REACT_APP_BACKEND_URL=https://your-domain.com

# --- OpenClaw (AI Assistant via Telegram) ---
# Google Gemini API key (free tier: 250 req/day)
# Get at: https://aistudio.google.com/apikeys
GEMINI_API_KEY=
# Telegram bot token (create via @BotFather)
OPENCLAW_TELEGRAM_BOT_TOKEN=
# Your Telegram numeric user ID (get via @userinfobot)
OPENCLAW_TELEGRAM_OWNER_ID=
# Gateway auth token (auto-generated if empty)
OPENCLAW_GATEWAY_TOKEN=
