{
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan"
  },
  "agents": {
    "defaults": {
      "model": "google:gemini-2.5-flash"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["${OWNER_ID}"],
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  }
}
