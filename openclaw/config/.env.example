# =============================================================================
# OpenClaw - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# Location on VPS: /opt/licitometro/openclaw/config/.env

# --- Google Gemini (Free Tier) ---
# Get your API key at: https://aistudio.google.com/apikeys
GEMINI_API_KEY=your_gemini_api_key_here

# --- Telegram Bot ---
# Create a bot via @BotFather on Telegram:
#   1. Open Telegram, search @BotFather
#   2. Send /newbot
#   3. Choose name: "Licitometro AI" (or any name)
#   4. Choose username: licitometro_ai_bot (must end in "bot")
#   5. Copy the token below
OPENCLAW_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (numeric)
# To find it: message @userinfobot on Telegram, it replies with your ID
OPENCLAW_TELEGRAM_OWNER_ID=your_telegram_user_id_here

# --- Gateway Security ---
# Auto-generated on first run if empty. Set explicitly to persist across restarts.
OPENCLAW_GATEWAY_TOKEN=

# --- Optional: Anthropic (if you get an API key later) ---
# ANTHROPIC_API_KEY=sk-ant-...
