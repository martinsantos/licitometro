{
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan"
  },
  "agents": {
    "defaults": {
      "model": "google:gemini-2.5-flash",
      "maxTokens": 8192
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["${OWNER_ID}"],
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "mcpServers": {
    "licitometro": {
      "command": "node",
      "args": ["/home/node/mcp-licitometro/index.js"],
      "env": {
        "LICITOMETRO_API_URL": "http://backend:8000/api"
      }
    }
  }
}
