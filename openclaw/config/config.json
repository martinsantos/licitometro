{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "0.0.0.0"
  },
  "agent": {
    "provider": "google",
    "model": "gemini-2.5-flash",
    "maxTokens": 8192,
    "temperature": 0.7,
    "workspace": "/opt/openclaw/workspace"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["${OWNER_ID}"],
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "mcpServers": {
    "licitometro": {
      "command": "node",
      "args": ["/opt/openclaw/mcp-licitometro/index.js"],
      "env": {
        "LICITOMETRO_API_URL": "http://127.0.0.1/api"
      }
    }
  },
  "persona": {
    "name": "Licitobot",
    "description": "Asistente inteligente de licitaciones publicas de Mendoza, Argentina. Busco, analizo y te ayudo con procesos de compra del Estado."
  }
}
